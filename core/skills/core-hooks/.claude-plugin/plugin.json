{
  "name": "core-hooks",
  "version": "0.13.0",
  "description": "Hooks-only plugin. SessionStart surfaces plugin-hook mechanics and the optional mandatory-skills preamble. PreToolUse blocks edits to secrets, dangerous shell, and — when enforcement mode is opted in via .claude/enforcement.json — a per-pack rule registry, plus an opt-in plan-required gate that blocks the Nth unique non-trivial file edit per session until a craft:plan block exists in the conversation. PostToolUse runs post-test on every Write/Edit/MultiEdit (detects stack, runs related fast tests, exit 2 on failure forces fix). Stop hook blocks turn-end until each mandatory pack's gate command has passed AND surfaces honesty violations (cite-or-read: factual claims about files not Read/Grep'd in the same turn — non-blocking WARN). Pure bash + jq.",
  "author": {
    "name": "pixelcrafts",
    "url": "https://github.com/pixelcrafts-app"
  },
  "homepage": "https://github.com/pixelcrafts-app/claude-craft",
  "license": "MIT",
  "keywords": ["hooks", "safety", "secrets", "cross-stack", "quality"],
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/rules-discipline.sh"
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/enforcement-preamble.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/protect-files.sh"
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/enforce-rules.sh"
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/plan-required.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/protect-bash.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/post-test.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/stop-gate.sh"
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/cite-or-read.sh"
          }
        ]
      }
    ]
  }
}
